# Your Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Paste the ENTIRE contents of your service account JSON here (as one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# The Google Workspace admin email used for domain-wide delegation
# (the service account will impersonate this user to access all Drive files)
GOOGLE_ADMIN_EMAIL=peter@cdentalarts.com

# Only allow logins from this domain (leave blank to allow any Google account)
ALLOWED_DOMAIN=cdentalarts.com

# URL of your frontend (for CORS)
FRONTEND_URL=http://localhost:3000
